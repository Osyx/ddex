{
  "name": "discord-mcd",
  "version": "0.0.2",
  "description": "Offline CLI tool that analyses a Discord GDPR data export and reports your most-used words with fuzzy clustering",
  "keywords": [
    "discord",
    "gdpr",
    "export",
    "word-frequency",
    "cli",
    "privacy",
    "analysis"
  ],
  "author": "Osyx",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/Osyx/discord-mcd#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Osyx/discord-mcd.git"
  },
  "bugs": {
    "url": "https://github.com/Osyx/discord-mcd/issues"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "module": "src/index.ts",
  "dependencies": {
    "csv-parse": "^6.1.0",
    "double-metaphone": "^2.0.1",
    "fastest-levenshtein": "^1.0.16",
    "stopword": "^3.1.5",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/stopword": "^2.0.3",
    "@types/yauzl": "^2.10.3",
    "jszip": "^3.10.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0",
    "typescript": "^5.9.3"
  },
  "private": true,
  "scripts": {
    "build": "bun build --compile --minify src/index.ts --outfile discord-mcd",
    "build:linux-x64": "bun build --compile --minify --target=bun-linux-x64 src/index.ts --outfile dist/discord-mcd-linux-x64",
    "build:linux-arm64": "bun build --compile --minify --target=bun-linux-arm64 src/index.ts --outfile dist/discord-mcd-linux-arm64",
    "build:macos-x64": "bun build --compile --minify --target=bun-darwin-x64 src/index.ts --outfile dist/discord-mcd-macos-x64",
    "build:macos-arm64": "bun build --compile --minify --target=bun-darwin-arm64 src/index.ts --outfile dist/discord-mcd-macos-arm64",
    "build:windows-x64": "bun build --compile --minify --target=bun-windows-x64 src/index.ts --outfile dist/discord-mcd-windows-x64.exe",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:macos-x64 && bun run build:macos-arm64 && bun run build:windows-x64",
    "test": "bun test src/__tests__/tokenizer.test.ts src/__tests__/stopwords.test.ts src/__tests__/grouper.test.ts src/__tests__/formatter.test.ts src/__tests__/db.test.ts src/__tests__/parser.test.ts",
    "test:binary": "bun test src/__tests__/binary.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware",
    "check": "oxlint --type-aware --type-check",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "lefthook install"
  },
  "type": "module"
}
